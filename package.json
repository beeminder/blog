{
  "name": "beeblog",
  "type": "module",
  "version": "2024.04.16-a",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9.0.2"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "node ./scripts/image-cache.mjs && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:snapshot": "vitest --config ./vitest.snapshot.config.ts",
    "test:snapshot:update": "vitest --config ./vitest.snapshot.config.ts --update",
    "cache:clear": "rm -rf .cache && rm -rf node_modules/.astro",
    "check": "astro check",
    "check:ts": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "preinstall": "npx only-allow pnpm",
    "puppeteer": "tsx ./scripts/puppeteer.ts",
    "puppeteer:report": "tsx ./scripts/puppeteer-report.ts",
    "puppeteer:reset": "pnpm run cache:clear && pnpm run build && rm -rf ./shots && mkdir ./shots",
    "knip": "knip"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.2.1",
    "@fontsource-variable/lora": "^5.2.8",
    "@fontsource/source-sans-pro": "^5.2.5",
    "astro": "^4.16.7",
    "dotenv": "^17.4.0",
    "expost": "github:bsoule/expost#920313519f180153c00f2f4f4c78b4f86974517e",
    "feather-icons": "^4.29.2",
    "happy-dom": "^20.8.9",
    "levenshtein": "^1.0.5",
    "memize": "^2.1.1",
    "node-fetch-cache": "^3.1.4",
    "p-limit": "^7.3.0",
    "sharp": "^0.34.5",
    "striptags": "^3.2.0",
    "tsx": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/diffable-html": "^5.0.2",
    "@types/feather-icons": "^4.29.4",
    "@types/levenshtein": "^1.0.4",
    "@types/node": "^25.5.2",
    "@types/node-fetch-cache": "^3.0.5",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@vitest/ui": "^2.1.9",
    "diffable-html": "^6.0.1",
    "eslint": "^10.1.0",
    "knip": "^6.3.0",
    "pixelmatch": "^7.1.0",
    "pixelteer": "github:narthur/pixelteer",
    "pngjs": "^7.0.0",
    "prettier": "3.8.1",
    "puppeteer": "24.40.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.1.9"
  }
}
