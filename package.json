{
  "name": "beeblog",
  "type": "module",
  "version": "2024.04.16-a",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.0.2"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "[ -z \"$RENDER\" ] || pnpm install --frozen-lockfile",
    "build": "node ./scripts/image-cache.mjs && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:snapshot": "vitest --config ./vitest.snapshot.config.ts",
    "test:snapshot:update": "vitest --config ./vitest.snapshot.config.ts --update",
    "cache:clear": "rm -rf .cache && rm -rf node_modules/.astro",
    "check": "astro check",
    "check:secrets": "tsx ./scripts/check-no-etherpad-domain.ts",
    "check:i18n": "tsx ./scripts/check-i18n-placeholders.ts",
    "check:strings": "tsx ./scripts/check-strings-authorship.ts",
    "check:ts": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "preinstall": "npx only-allow pnpm",
    "puppeteer": "tsx ./scripts/puppeteer.ts",
    "puppeteer:report": "tsx ./scripts/puppeteer-report.ts",
    "puppeteer:reset": "pnpm run cache:clear && pnpm run build && rm -rf ./shots && mkdir ./shots",
    "knip": "knip",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/lora": "^5.2.8",
    "@fontsource/source-sans-pro": "^5.2.5",
    "astro": "^7.0.6",
    "dotenv": "^17.4.2",
    "expost": "https://github.com/bsoule/expost/releases/download/v1.0.0/expost-1.0.0.tgz",
    "feather-icons": "^4.29.2",
    "happy-dom": "^20.10.6",
    "levenshtein": "^1.0.5",
    "memize": "^2.1.1",
    "node-fetch-cache": "^5.1.0",
    "p-limit": "^7.3.0",
    "sharp": "^0.35.3",
    "striptags": "^3.2.0",
    "tsx": "^4.23.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/diffable-html": "^5.0.2",
    "@types/feather-icons": "^4.29.4",
    "@types/levenshtein": "^1.0.4",
    "@types/node": "^26.1.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@vitest/ui": "^4.1.10",
    "astro-eslint-parser": "^2.1.0",
    "diffable-html": "^6.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-i18next": "^6.1.5",
    "husky": "^9.1.7",
    "knip": "^6.24.0",
    "lint-staged": "^17.0.8",
    "pixelmatch": "^7.2.0",
    "pixelteer": "https://github.com/pinepeakdigital/pixelteer/releases/download/v1.0.0/pixelteer-1.0.0.tgz",
    "pngjs": "^7.0.0",
    "prettier": "3.9.4",
    "puppeteer": "25.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "packageManager": "pnpm@10.34.5"
}
