---
import type { InferGetStaticPropsType } from "astro";
import Tags from "../components/Tags.astro";
import getPosts from "../lib/getPosts";
import Shadowbox from "../components/Shadowbox.astro";
import PostMeta from "../components/PostMeta.astro";
import Typography from "../components/Typography.astro";
import Comments from "../components/Comments.astro";
import RecommendedPosts from "../components/RecommendedPosts.astro";
import type { Post } from "../schemas/post";
import Paginated from "../layouts/Paginated.astro";

export async function getStaticPaths() {
  const posts = await getPosts({
    includeUnpublished: true,
    sort: true,
  });

  const published = (p: Post) => p.status === "publish";
  const publishedPosts = posts.filter(published);

  const tagIndex = new Map<string, Post[]>();
  for (const p of publishedPosts) {
    for (const tag of p.tags) {
      const list = tagIndex.get(tag);
      if (list) list.push(p);
      else tagIndex.set(tag, [p]);
    }
  }

  const slugToPost = new Map(publishedPosts.map((p) => [p.slug, p]));
  const recommendedMap = new Map<string, Post[]>();
  for (const post of publishedPosts) {
    const scores = new Map<string, number>();
    for (const tag of post.tags) {
      for (const p of tagIndex.get(tag) ?? []) {
        if (p.slug !== post.slug) {
          scores.set(p.slug, (scores.get(p.slug) ?? 0) + 1);
        }
      }
    }
    const sorted = [...scores.entries()]
      .sort((a, b) => b[1] - a[1] || slugToPost.get(b[0])!.date.getTime() - slugToPost.get(a[0])!.date.getTime())
      .slice(0, 6)
      .map(([slug]) => slugToPost.get(slug)!);
    recommendedMap.set(post.slug, sorted);
  }

  return posts.map((post: Post, i: number) => ({
    params: {
      slug: post.slug,
    },
    props: {
      post,
      newer: posts.slice(0, i).reverse().find(published),
      older: posts.slice(i + 1).find(published),
      recommendedPosts: recommendedMap.get(post.slug) ?? [],
    },
  }));
}

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { post, newer, older, recommendedPosts } = Astro.props as Props;
const { content, title, tags, disqus_id, excerpt, image, status, slug } = post;

const isDraft = status === "draft";
const className = isDraft ? "draft" : undefined;
const { extracted, ...imageProps } = image || {};
---

<Paginated
  title={title}
  description={excerpt}
  image={image?.src}
  next={newer && {
    title: newer.title,
    url: `/${newer.slug}`,
  }}
  previous={older && {
    title: older.title,
    url: `/${older.slug}`,
  }}
>
  <div class="post">
    <Shadowbox padding={2} class={className}>
      <PostMeta
        post={{
          ...post,
          title,
        }}
        includeExcerpt={false}
        linkTitle={false}
        Heading="h1"
      />
      {extracted ? undefined : <img class="aligncenter" {...imageProps} />}
      <Typography set:html={content} />
      <Tags tags={tags} />
    </Shadowbox>

    {!isDraft && recommendedPosts.length > 0 && <RecommendedPosts posts={recommendedPosts} />}

    <Shadowbox id="comments" padding={2}>
      {
        isDraft ? (
          <p>Comments are disabled on DRAFT pages.</p>
        ) : (
          <Comments
            id={disqus_id}
            url={`https://blog.beeminder.com/${slug}/`}
          />
        )
      }
    </Shadowbox>
  </div>
</Paginated>

<style>
  .post :global(.draft) {
    border: 1rem solid #ff700a;
  }
</style>
