---
import type { InferGetStaticParamsType, InferGetStaticPropsType } from "astro";
import Layout from "../../layouts/Layout.astro";
import getPosts from "../../lib/getPosts";
import Posts from "../../components/Posts.astro";
import TitleLockup from "../../components/TitleLockup.astro";
import { strings } from "../../i18n";

export async function getStaticPaths() {
  const posts = await getPosts();
  const authors = [...new Set(posts.map((post) => post.author))];

  return authors.map((a) => ({
    params: {
      author: a,
    },
    props: {
      posts: posts.filter((p) => p.author === a),
    },
  }));
}

type Params = InferGetStaticParamsType<typeof getStaticPaths>;
type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { author } = Astro.params as Params;
const { posts } = Astro.props as Props;

const title = strings.listing.authorTitle(author);
---

<Layout title={title}>
  <TitleLockup slot="before-content" Heading="h1" title={title}
    >{strings.listing.postCount(posts.length)}</TitleLockup
  >
  <Posts posts={posts} />
</Layout>
