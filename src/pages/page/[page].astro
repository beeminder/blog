---
import type { GetStaticPaths, Page } from "astro";
import getPosts from "../../lib/getPosts";
import Posts from "../../components/Posts.astro";
import type { Post } from "../../schemas/post";
import Paginated from "../../layouts/Paginated.astro";
import { strings } from "../../i18n";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts = await getPosts({
    sort: true
  });

  return paginate(posts, {
    pageSize: 10,
  });
};

interface Props {
  page: Page<Post>;
}

const { page } = Astro.props;

const older = page.url.next
  ? {
      url: page.url.next,
      title: strings.pagination.older,
    }
  : undefined;

const newer = page.url.prev
  ? {
      url: page.currentPage === 2 ? "/" : page.url.prev,
      title: strings.pagination.newer,
    }
  : undefined;

---

<Paginated title={strings.listing.pageTitle(page.currentPage)} previous={older} next={newer}>
  <Posts posts={page.data} />
</Paginated>