---
import Icon from "./Icon.astro";
import { strings } from "../i18n";
---

<div class="header">
  <div class="inner">
    <div>
      <a href="https://beeminder.com">{strings.header.beeminderHome}</a>
      <h2>
        <a href="/">{strings.header.blogTitle}</a>
      </h2>
    </div>

    <div class="icons">
      <a
        title={strings.header.emailNotifications}
        href="https://cdn.forms-content.sg-form.com/b52c80cd-404f-11ee-90d4-4aa896d8a9ad"
        ><Icon name="mail" /></a
      >
      <a title={strings.header.subscribeRss} href="/feed.xml"
        ><Icon name="rss" /></a
      >
      <a title={strings.header.followTwitter} href="http://twitter.com/bmndr"
        ><Icon name="twitter" /></a
      >
      <a title={strings.header.followFacebook} href="http://beeminder.com/facebook"
        ><Icon name="facebook" /></a
      >
    </div>
  </div>
</div>

<style>
  .header {
    background-color: var(--secondary);
    box-shadow: 0 -9px 5px 10px #a9a9a9;
  }
  .inner {
    padding: var(--gap-2) var(--gap-2);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    max-width: var(--content-width);
    margin: 0 auto;
  }
  .header a {
    color: var(--black);
  }
  .header a:hover {
    text-decoration: none;
    color: var(--primary);
  }
  .header h2 {
    margin: 0;
    font-size: 2.5em;
  }
  .header h2 a {
    font-weight: 900;
  }
  .icons {
    text-align: right;
  }

  @media (max-width: 900px) {
    .inner {
      padding: var(--gap-1);
    }
  }
</style>
