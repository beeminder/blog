---
import { strings } from "../i18n";
---

<div class="footer" set:html={strings.footer.credit} />

<style>
  .footer {
    background-color: var(--black);
    color: white;
    padding: var(--gap);
    font-size: 0.75em;
    text-align: center;
  }

  /* The footer content is injected via set:html, so its <a> elements don't
     receive Astro's scoping attribute — target them with :global(). */
  .footer :global(a) {
    color: var(--secondary);
  }
</style>
